{
  "mcpServers": {
    "ctxloom": {
      "command": "/home/babbitt/go/bin/ctxloom",
      "args": [
        "mcp"
      ],
      "cwd": "${CLAUDE_PROJECT_DIR}",
      "_ctxloom": "ctxloom-auto"
    },
    "mcp-tasks": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-tasks"
      ]
    },
    "scm": {
      "command": "/home/babbitt/go/bin/scm",
      "args": [
        "mcp"
      ],
      "cwd": "${CLAUDE_PROJECT_DIR}"
    }
  }
}