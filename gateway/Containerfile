# Build stage
FROM docker.io/golang:1.23-alpine AS builder

RUN apk add --no-cache git

WORKDIR /workspace

# Install buf (v1.47.2 works with Go 1.23)
RUN go install github.com/bufbuild/buf/cmd/buf@v1.47.2

# Copy proto files for generation
COPY proto/ ./proto/

# Copy gateway module
COPY gateway/ ./gateway/

WORKDIR /workspace/gateway

# Download dependencies
RUN go mod download

# Generate protobuf code (buf.gen.yaml inputs: ../proto)
RUN buf generate

# Build the binary
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /grpc-gateway .

# Runtime stage
FROM gcr.io/distroless/static-debian12:nonroot

COPY --from=builder /grpc-gateway /app/grpc-gateway
COPY --from=builder /workspace/gateway/api/ /app/api/

WORKDIR /app

EXPOSE 8080

ENTRYPOINT ["/app/grpc-gateway"]
