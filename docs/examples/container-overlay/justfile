# justfile - runs on host, delegates to container
# Demonstrates the container overlay pattern

IMAGE := "overlay-demo:latest"

# Container invocation with overlay mount
# Key: justfile.container is mounted OVER justfile inside container
_run +ARGS:
    podman run --rm \
        -v ./:/workspace \
        -v ./justfile.container:/workspace/justfile:ro \
        -w /workspace \
        {{IMAGE}} just {{ARGS}}

# Build the demo image (alpine + just + make, ~12MB)
image:
    podman build -t {{IMAGE}} -f Containerfile.just .

build: image
    just _run build

test: image
    just _run test

info: image
    just _run info

# Demonstrate the pattern
demo: image
    @echo "=== Host Environment ==="
    @echo "Hostname: $(hostname)"
    @echo "This justfile: justfile (host version)"
    @echo ""
    @echo "=== Running 'just info' (delegates to container) ==="
    @echo ""
    just _run info

clean:
    podman rmi {{IMAGE}} 2>/dev/null || true
