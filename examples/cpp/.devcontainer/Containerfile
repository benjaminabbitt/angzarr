# C++ examples devcontainer
# Uses custom base image from ghcr.io/angzarr

ARG CPP_IMAGE=ghcr.io/angzarr-io/angzarr-cpp:latest
FROM ${CPP_IMAGE}

# Install dependencies for cucumber-cpp BDD tests
USER root
RUN apt-get update && apt-get install -y --no-install-recommends \
    libboost-regex-dev \
    libboost-filesystem-dev \
    libboost-system-dev \
    libboost-program-options-dev \
    libboost-thread-dev \
    nlohmann-json3-dev \
    libasio-dev \
    libtclap-dev \
    ruby \
    ruby-dev \
    && rm -rf /var/lib/apt/lists/* \
    && gem install bundler --no-document

# Mark as devcontainer for justfile detection
ENV DEVCONTAINER=true
