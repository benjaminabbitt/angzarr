# C++ poker examples - container execution
#
# This file runs inside the devcontainer and executes actual build commands.
# It's mounted over justfile when running in a container.

set shell := ["bash", "-c"]

BUILD_DIR := "build"

default:
    @just --list

# Configure and build all C++ components
build:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)

# Run unit tests
test-unit:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)
    cd {{BUILD_DIR}} && ctest --output-on-failure -L unit || echo "No unit tests labeled"

# Run acceptance tests (BDD/Gherkin)
# cucumber-cpp uses a wire protocol: the C++ test binary runs as a server,
# and cucumber (Ruby) connects to it to execute the feature files.
test-acceptance:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON
    cmake --build {{BUILD_DIR}} -j$(nproc)
    # Install cucumber gems via bundler
    cd features && bundle install --quiet
    # Start the wire server in background
    ./{{BUILD_DIR}}/tests/acceptance_tests -p 3902 &
    WIRE_PID=$$!; \
    sleep 1; \
    cd features && CUCUMBER_PUBLISH_QUIET=true bundle exec cucumber --require step_definitions --format progress . || { kill $$WIRE_PID 2>/dev/null; exit 1; }; \
    kill $$WIRE_PID 2>/dev/null || true

# Run all tests
test: test-unit test-acceptance

# Format code with clang-format
fmt:
    find . -name "*.cpp" -o -name "*.hpp" | grep -v build | xargs clang-format -i

# Lint with clang-tidy
lint:
    cmake -B {{BUILD_DIR}} -S . -DBUILD_TESTS=ON -DCMAKE_EXPORT_COMPILE_COMMANDS=ON
    find . -name "*.cpp" | grep -v build | xargs clang-tidy -p {{BUILD_DIR}}

# Clean build artifacts
clean:
    rm -rf {{BUILD_DIR}}
