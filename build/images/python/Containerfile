# syntax=docker/dockerfile:1.4
# Python build image for angzarr
#
# Build: podman build -t ghcr.io/angzarr-io/angzarr-python .
#
# Provides: Python 3.11, pip, uv, grpcio-tools
# Based on: ghcr.io/angzarr-io/angzarr-base

# BASE_IMAGE must be provided via build arg (no default to avoid registry lookups)
ARG BASE_IMAGE
FROM ${BASE_IMAGE}

ARG UV_VERSION=0.10.3

# Install Python (Debian Bookworm ships with 3.11)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-dev \
    python3-venv \
    python3-pip \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python

# Install uv (fast Python package manager)
RUN curl -LsSf https://astral.sh/uv/${UV_VERSION}/install.sh | sh
ENV PATH=/root/.local/bin:$PATH

# Install grpcio-tools for protobuf code generation
RUN pip install --no-cache-dir --break-system-packages grpcio-tools

# Install formatters (black, ruff)
RUN uv tool install black && uv tool install ruff

# Verify installations
RUN python --version && uv --version && python -c "import grpc_tools.protoc" && \
    black --version && ruff --version

WORKDIR /workspace
