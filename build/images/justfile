# Base image build commands
# Usage from root: just images <target>

set shell := ["bash", "-c"]

REGISTRY := "ghcr.io/angzarr-io"
TOP := `git rev-parse --show-toplevel`

default:
    @just --list

# Build all images (base + all languages)
build-all: build-base build-languages

# Build base image
build-base:
    podman build --network=host \
        -t {{REGISTRY}}/angzarr-base:latest \
        -f "{{TOP}}/build/images/base/Containerfile" \
        "{{TOP}}/build/images/base"

# Build all language-specific images
build-languages: build-base
    #!/usr/bin/env bash
    set -e
    for lang in rust go python java csharp cpp; do
        echo "=== Building $lang image ==="
        just build "$lang"
    done

# Build specific language image
build LANG: build-base
    podman build --network=host \
        --build-arg BASE_IMAGE={{REGISTRY}}/angzarr-base:latest \
        -t {{REGISTRY}}/angzarr-{{LANG}}:latest \
        -f "{{TOP}}/build/images/{{LANG}}/Containerfile" \
        "{{TOP}}/build/images/{{LANG}}"

# Push all images to registry
push-all: push-base push-languages

# Push base image
push-base:
    podman push {{REGISTRY}}/angzarr-base:latest

# Push all language images
push-languages:
    #!/usr/bin/env bash
    set -e
    for lang in rust go python java csharp cpp; do
        echo "=== Pushing $lang image ==="
        just push "$lang"
    done

# Push specific language image
push LANG:
    podman push {{REGISTRY}}/angzarr-{{LANG}}:latest

# Pull all images from registry (tries branch tag, falls back to latest)
pull-all:
    #!/usr/bin/env bash
    set -e
    for img in base rust go python java csharp cpp; do
        echo "=== Pulling $img image ==="
        just pull "$img"
    done

# Pull specific image (tries branch tag, falls back to latest)
pull IMAGE:
    #!/usr/bin/env bash
    set -e
    REGISTRY="{{REGISTRY}}"
    IMAGE="{{IMAGE}}"

    # Get current branch and sanitize for docker tag
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    BRANCH_TAG=$(echo "$BRANCH" | sed 's/[^a-zA-Z0-9._-]/-/g' | tr '[:upper:]' '[:lower:]')

    # Try branch-specific tag first (pr-<branch> format from CI)
    if [ "$BRANCH" != "main" ]; then
        PR_TAG="pr-$BRANCH_TAG"
        echo "Trying $REGISTRY/angzarr-$IMAGE:$PR_TAG..."
        if podman pull "$REGISTRY/angzarr-$IMAGE:$PR_TAG" 2>/dev/null; then
            echo "Pulled branch-specific image: $PR_TAG"
            # Tag as latest locally for consistency
            podman tag "$REGISTRY/angzarr-$IMAGE:$PR_TAG" "$REGISTRY/angzarr-$IMAGE:latest"
            exit 0
        fi
        echo "Branch tag not found, falling back to latest..."
    fi

    # Fall back to latest
    podman pull "$REGISTRY/angzarr-$IMAGE:latest"

# Pull core runtime images (tries branch tag, falls back to latest)
pull-core:
    #!/usr/bin/env bash
    set -e
    for img in aggregate projector saga process-manager log stream topology; do
        echo "=== Pulling $img image ==="
        just pull-core-image "$img"
    done

# Pull specific core image (tries branch tag, falls back to latest)
pull-core-image IMAGE:
    #!/usr/bin/env bash
    set -e
    REGISTRY="{{REGISTRY}}"
    IMAGE="{{IMAGE}}"

    # Get current branch and sanitize for docker tag
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    BRANCH_TAG=$(echo "$BRANCH" | sed 's/[^a-zA-Z0-9._-]/-/g' | tr '[:upper:]' '[:lower:]')

    # Try branch-specific tag first (pr-<branch> format from CI)
    # Core images have -dev suffix in CI
    if [ "$BRANCH" != "main" ]; then
        PR_TAG="pr-$BRANCH_TAG"
        echo "Trying $REGISTRY/angzarr-$IMAGE-dev:$PR_TAG..."
        if podman pull "$REGISTRY/angzarr-$IMAGE-dev:$PR_TAG" 2>/dev/null; then
            echo "Pulled branch-specific image: $PR_TAG"
            podman tag "$REGISTRY/angzarr-$IMAGE-dev:$PR_TAG" "$REGISTRY/angzarr-$IMAGE:latest"
            exit 0
        fi
        echo "Branch tag not found, falling back to latest..."
    fi

    # Fall back to latest
    if podman pull "$REGISTRY/angzarr-$IMAGE-dev:latest" 2>/dev/null; then
        podman tag "$REGISTRY/angzarr-$IMAGE-dev:latest" "$REGISTRY/angzarr-$IMAGE:latest"
    else
        podman pull "$REGISTRY/angzarr-$IMAGE:latest"
    fi

# Load image into Kind cluster
load IMAGE CLUSTER="angzarr":
    kind load docker-image {{REGISTRY}}/angzarr-{{IMAGE}}:latest --name {{CLUSTER}}

# Load all language images into Kind cluster
load-all CLUSTER="angzarr":
    #!/usr/bin/env bash
    set -e
    for lang in rust go python java csharp cpp; do
        echo "=== Loading $lang image into Kind ==="
        just load "$lang" "{{CLUSTER}}"
    done

# List all local angzarr images
list:
    @podman images --filter "reference={{REGISTRY}}/angzarr-*" --format "table {{{{.Repository}}}}:{{{{.Tag}}}}\t{{{{.Size}}}}\t{{{{.Created}}}}"

# Remove all local angzarr images
clean:
    @podman images --filter "reference={{REGISTRY}}/angzarr-*" -q | xargs -r podman rmi -f
