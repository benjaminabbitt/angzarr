# Angzarr - container version
# This file is mounted as 'justfile' inside the container

set shell := ["bash", "-c"]

default:
    @just --list

build:
    cargo build

build-release:
    cargo build --release

# Build standalone binary with all features needed for integration tests
build-standalone:
    cargo build --release --bin angzarr-standalone --features "standalone,amqp"

check:
    cargo check

fmt:
    cargo fmt

lint:
    cargo clippy -- -D warnings

test:
    cargo test --lib

# === Contract Tests ===
# These tests verify that storage and bus implementations correctly fulfill their trait contracts.

# --- Direct Contract Tests (macro-based) ---
# Fast verification of specific backend implementations.

# Run PostgreSQL storage contract tests (requires podman socket)
test-contract-postgres:
    cargo test --test storage_postgres --features postgres -- --nocapture

# Run Redis storage contract tests (requires podman socket)
test-contract-redis:
    cargo test --test storage_redis --features redis -- --nocapture

# Run NATS storage contract tests (requires podman socket)
test-contract-nats-storage:
    cargo test --test storage_nats --features nats -- --nocapture

# Run NATS bus contract tests (requires podman socket)
test-contract-nats-bus:
    cargo test --test bus_nats --features nats,test-utils -- --nocapture

# --- Interface Contract Tests (Gherkin/Cucumber) ---
# Comprehensive contract verification with readable specifications.

# Run interface tests against SQLite (in-memory, no containers)
test-interfaces:
    cargo test --test interfaces --features "sqlite test-utils"

# Run interface tests against PostgreSQL (requires podman socket)
test-interfaces-postgres:
    STORAGE_BACKEND=postgres cargo test --test interfaces --features "postgres test-utils"

# Run interface tests against Redis (requires podman socket)
test-interfaces-redis:
    STORAGE_BACKEND=redis cargo test --test interfaces --features "redis test-utils"

# --- Bus Contract Tests (direct) ---
# These tests verify event bus implementations correctly fulfill the EventBus trait contract.

# Run AMQP/RabbitMQ bus contract tests (requires podman socket)
# Uses --test-threads=1 to avoid parallel container starts causing resource contention
test-bus-amqp:
    cargo test --test bus_amqp --features amqp -- --test-threads=1

# Run Kafka bus contract tests (requires podman socket)
# Uses --test-threads=1 to avoid parallel container starts causing resource contention
test-bus-kafka:
    cargo test --test bus_kafka --features kafka -- --test-threads=1

# Run GCP Pub/Sub bus contract tests (requires podman socket)
# Uses --test-threads=1 because tests share PUBSUB_EMULATOR_HOST env var
test-bus-pubsub:
    cargo test --test bus_pubsub --features pubsub -- --test-threads=1

# Run AWS SNS/SQS bus contract tests (requires podman socket)
# Uses --test-threads=1 because tests start LocalStack containers with port bindings
test-bus-sns-sqs:
    cargo test --test bus_sns_sqs --features sns-sqs -- --test-threads=1

# Clean up any zombie containers from failed test runs
clean-containers:
    podman container prune -f || true

# Run all bus tests (with container cleanup between runs)
test-bus-all: clean-containers test-bus-amqp clean-containers test-bus-kafka clean-containers test-bus-pubsub clean-containers test-bus-sns-sqs

clean:
    cargo clean

# === Coverage ===
# Uses cargo-llvm-cov for accurate line/branch coverage.
# Excludes: proto generated code, build.rs, main.rs binaries.

COV_IGNORE := "--ignore-filename-regex '(proto/|build\\.rs|main\\.rs)'"
COV_FEATURES := "--features 'sqlite test-utils'"

# Run unit tests with coverage
cov-unit:
    cargo llvm-cov --lib {{COV_FEATURES}} {{COV_IGNORE}}

# Run standalone integration tests with coverage
cov-integration:
    cargo llvm-cov --test standalone_integration {{COV_FEATURES}} {{COV_IGNORE}}

# Run interface/Gherkin tests with coverage
cov-gherkin:
    cargo llvm-cov --test interfaces {{COV_FEATURES}} {{COV_IGNORE}}

# Run all local tests with coverage (unit + integration + gherkin + client)
cov:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}}

# Quick terminal summary of coverage (all local tests)
cov-summary:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --summary-only

# Generate HTML coverage report (all local tests)
cov-html:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --html
    @echo "Coverage report generated at target/llvm-cov/html/index.html"

# Generate LCOV format for CI integration
cov-lcov:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --lcov --output-path target/llvm-cov/lcov.info

# === Contract Test Coverage (requires testcontainers/docker socket) ===

# Run PostgreSQL contract tests with coverage
cov-contract-postgres:
    cargo llvm-cov --test interfaces --features "postgres test-utils" {{COV_IGNORE}}

# Run Redis contract tests with coverage
cov-contract-redis:
    cargo llvm-cov --test interfaces --features "redis test-utils" {{COV_IGNORE}}

# Run AMQP bus contract tests with coverage
cov-contract-amqp:
    cargo llvm-cov --test bus_amqp --features amqp {{COV_IGNORE}} -- --test-threads=1

# Run Kafka bus contract tests with coverage
cov-contract-kafka:
    cargo llvm-cov --test bus_kafka --features kafka {{COV_IGNORE}} -- --test-threads=1

# Run all contract tests with combined coverage (requires docker socket)
cov-contracts:
    cargo llvm-cov \
        --test interfaces \
        --test bus_amqp \
        --features "postgres test-utils amqp" \
        {{COV_IGNORE}} \
        -- --test-threads=1

# === Full Coverage (all test types) ===

# Run all tests with combined coverage (local + contracts, requires docker socket)
cov-full:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}}

# Full coverage with HTML report (requires docker socket)
cov-full-html:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}} \
        --html
    @echo "Full coverage report generated at target/llvm-cov/html/index.html"

# Full coverage summary (requires docker socket)
cov-full-summary:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}} \
        --summary-only

# === Mutation Testing ===
# Uses cargo-mutants to verify test quality by introducing mutations.
# Mutations that aren't caught by tests indicate weak test coverage.
# Output: mutants.out/ (gitignored)
#
# Uses --in-place to avoid copying the entire workspace (saves ~200GB disk).
# Safe because mutations are reverted after each test.

MUTANTS_TIMEOUT := "120"
MUTANTS_FEATURES := "--features 'sqlite test-utils'"

# Run mutation tests on a specific file
mutants FILE:
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f {{FILE}} \
        -- {{MUTANTS_FEATURES}}

# Run mutation tests on handlers/core (aggregate, projector, saga, PM)
mutants-core:
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/handlers/core/aggregate.rs \
        -f src/handlers/core/projector.rs \
        -f src/handlers/core/saga.rs \
        -f src/handlers/core/process_manager.rs \
        -- {{MUTANTS_FEATURES}}
    @just mutants-summary

# Alias for backwards compatibility
mutants-handlers: mutants-core

# Run mutation tests on bus module (event routing)
mutants-bus:
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/bus/traits.rs \
        -f src/bus/mod.rs \
        -- {{MUTANTS_FEATURES}}

# Run mutation tests on orchestration (saga, aggregate, PM)
mutants-orchestration:
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/orchestration/saga/mod.rs \
        -f src/orchestration/aggregate/mod.rs \
        -f src/orchestration/process_manager/mod.rs \
        -- {{MUTANTS_FEATURES}}

# Show mutation testing summary
mutants-summary:
    @if [ -f mutants.out/outcomes.json ]; then \
        caught=$$(jq '[.outcomes[] | select(.summary == "CaughtMutant")] | length' mutants.out/outcomes.json); \
        missed=$$(jq '[.outcomes[] | select(.summary == "MissedMutant")] | length' mutants.out/outcomes.json); \
        unviable=$$(jq '[.outcomes[] | select(.summary == "Unviable")] | length' mutants.out/outcomes.json); \
        total=$$((caught + missed)); \
        if [ $$total -gt 0 ]; then \
            rate=$$((100 * caught / total)); \
        else \
            rate=0; \
        fi; \
        echo ""; \
        echo "=== Mutation Testing Summary ==="; \
        echo "Caught (killed): $$caught"; \
        echo "Missed (survived): $$missed"; \
        echo "Unviable (won't compile): $$unviable"; \
        echo "Kill rate: $$rate% ($$caught/$$total viable)"; \
        echo ""; \
        if [ $$missed -gt 0 ]; then \
            echo "=== Surviving Mutants ==="; \
            jq -r '.outcomes[] | select(.summary == "MissedMutant") | .scenario' mutants.out/outcomes.json; \
        fi; \
    else \
        echo "No mutation results found. Run 'just mutants-core' first."; \
    fi

# List surviving mutants (mutations not caught by tests)
mutants-survivors:
    @if [ -f mutants.out/outcomes.json ]; then \
        jq -r '.outcomes[] | select(.summary == "MissedMutant") | .scenario' mutants.out/outcomes.json; \
    else \
        echo "No mutation results found. Run 'just mutants-core' first."; \
    fi

