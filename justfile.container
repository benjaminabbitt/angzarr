# Angzarr - container version
# This file is mounted as 'justfile' inside the container

set shell := ["bash", "-c"]

default:
    @just --list

build:
    cargo build

build-release:
    cargo build --release

# Build standalone binary with all features needed for integration tests
build-standalone:
    cargo build --release --bin angzarr-standalone --features "standalone,amqp"

check:
    cargo check

fmt:
    cargo fmt

lint:
    cargo clippy -- -D warnings

test:
    cargo test --lib

# === Storage Contract Tests ===
# =============================================================================
# Storage contract tests verify that storage implementations correctly fulfill
# their trait contracts (EventStore, SnapshotStore, PositionStore).
#
# WHY: Each backend has different consistency models, failure modes, and APIs.
# Contract tests ensure all implementations provide identical semantics despite
# underlying differences. A passing contract test means the backend can be
# swapped transparently without behavior changes.
#
# Usage:
#   just storage test              # All backends (default)
#   just storage sqlite test       # SQLite only (no containers)
#   just storage postgres test     # PostgreSQL only (testcontainers)
#   just storage redis test        # Redis only (testcontainers)
#   just storage immudb test       # ImmuDB only (testcontainers)
#   just storage nats test         # NATS JetStream only (testcontainers)
# =============================================================================

# Storage contract tests - run all backends or a specific one
# Usage: just storage test | just storage postgres test
storage *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    args="{{ARGS}}"
    if [[ "$args" == "test" ]] || [[ -z "$args" ]]; then
        just _storage-all
    else
        backend="${args%% *}"
        just "_storage-${backend}"
    fi

# Private: Run all storage backend tests
_storage-all: _storage-sqlite _storage-postgres _storage-redis _storage-immudb _storage-nats
    @echo "All storage contract tests passed"

# Private: SQLite storage tests (in-memory, no containers)
# WHY: Default local development backend. Fast, no setup. Validates all
# storage contracts in under a minute via Gherkin interface tests.
_storage-sqlite:
    @echo "=== Storage: SQLite (Gherkin interface tests) ==="
    cargo test --test interfaces --features "sqlite test-utils"

# Private: PostgreSQL storage tests (testcontainers)
# WHY: Production-grade RDBMS. Tests verify SQL schema correctness,
# transaction isolation, and ACID guarantees via Gherkin interface tests.
_storage-postgres:
    @echo "=== Storage: PostgreSQL (Gherkin interface tests) ==="
    STORAGE_BACKEND=postgres cargo test --test interfaces --features "postgres test-utils"

# Private: Redis storage tests (testcontainers)
# WHY: High-performance snapshot caching. Tests verify snapshot serialization,
# TTL handling, and Redis's eventual consistency model via direct macro tests.
_storage-redis:
    @echo "=== Storage: Redis (direct contract tests) ==="
    cargo test --test storage_redis --features redis -- --nocapture

# Private: ImmuDB storage tests (testcontainers)
# WHY: Cryptographically verifiable event storage. Tests verify events persist
# correctly via the PostgreSQL wire protocol adapter. Append-only by design.
_storage-immudb:
    @echo "=== Storage: ImmuDB (direct contract tests) ==="
    cargo test --test storage_immudb --features immudb -- --nocapture

# Private: NATS JetStream storage tests (testcontainers)
# WHY: Distributed event storage with replay capability. Tests verify events,
# snapshots, and positions work correctly in JetStream KV store.
_storage-nats:
    @echo "=== Storage: NATS JetStream (direct contract tests) ==="
    cargo test --test storage_nats --features nats -- --nocapture

# === Bus Contract Tests ===
# =============================================================================
# Bus contract tests verify that event bus implementations correctly fulfill
# the EventBus trait contract: publish, subscribe, acknowledge, nack, and DLQ.
#
# WHY: Event buses are the nervous system of the distributed architecture.
# Different backends have wildly different delivery semantics, ordering
# guarantees, and failure modes. Contract tests ensure all backends provide
# identical behavior to application code despite these differences.
#
# NOTE: All bus tests use --test-threads=1 to avoid testcontainer port conflicts.
#
# Usage:
#   just bus test                  # All backends (default)
#   just bus channel test          # Channel only (no containers)
#   just bus amqp test             # RabbitMQ only (testcontainers)
#   just bus kafka test            # Kafka only (testcontainers)
#   just bus pubsub test           # GCP Pub/Sub only (testcontainers)
#   just bus sns-sqs test          # AWS SNS/SQS only (testcontainers)
#   just bus nats test             # NATS JetStream only (testcontainers)
# =============================================================================

# Bus contract tests - run all backends or a specific one
# Usage: just bus test | just bus amqp test
bus *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    args="{{ARGS}}"
    if [[ "$args" == "test" ]] || [[ -z "$args" ]]; then
        just _bus-all
    else
        backend="${args%% *}"
        just "_bus-${backend}"
    fi

# Private: Run all bus backend tests (with container cleanup between runs)
# WHY: Cleanup prevents port conflicts and resource exhaustion from accumulated containers.
_bus-all: _bus-channel clean-containers _bus-amqp clean-containers _bus-kafka clean-containers _bus-pubsub clean-containers _bus-sns-sqs clean-containers _bus-nats
    @echo "All bus contract tests passed"

# Private: Channel bus tests (in-memory, no containers)
# WHY: Default local development bus. Validates bus contract without external deps.
# Uses Gherkin interface tests with BUS_BACKEND=channel.
_bus-channel:
    @echo "=== Bus: Channel (Gherkin interface tests) ==="
    BUS_BACKEND=channel cargo test --test interfaces --features "sqlite test-utils"

# Private: AMQP/RabbitMQ bus tests (testcontainers)
# WHY: Default production broker for k8s. Tests verify exchange/queue bindings,
# message routing, prefetch limits, acknowledgment, and dead-letter exchanges.
_bus-amqp:
    @echo "=== Bus: AMQP/RabbitMQ (direct contract tests) ==="
    cargo test --test bus_amqp --features amqp -- --test-threads=1

# Private: Kafka bus tests (testcontainers)
# WHY: High-throughput partitioned streaming. Tests verify topic creation,
# consumer group coordination, offset management, and at-least-once delivery.
_bus-kafka:
    @echo "=== Bus: Kafka (direct contract tests) ==="
    cargo test --test bus_kafka --features kafka -- --test-threads=1

# Private: GCP Pub/Sub bus tests (testcontainers emulator)
# WHY: Event bus for GCP deployments. Tests verify topic/subscription management,
# message ordering keys, and acknowledgment deadline extensions.
_bus-pubsub:
    @echo "=== Bus: GCP Pub/Sub (direct contract tests) ==="
    cargo test --test bus_pubsub --features pubsub -- --test-threads=1

# Private: AWS SNS/SQS bus tests (LocalStack testcontainer)
# WHY: Event bus for AWS deployments. Tests verify SNS fan-out to SQS queues,
# message attribute filtering, visibility timeout, and DLQ redrive policies.
_bus-sns-sqs:
    @echo "=== Bus: AWS SNS/SQS (direct contract tests) ==="
    cargo test --test bus_sns_sqs --features sns-sqs -- --test-threads=1

# Private: NATS JetStream bus tests (testcontainers)
# WHY: Distributed event bus with at-least-once delivery. Tests verify
# publish/subscribe, consumer groups, acknowledgment, and redelivery.
_bus-nats:
    @echo "=== Bus: NATS JetStream (direct contract tests) ==="
    cargo test --test bus_nats --features nats,test-utils -- --nocapture

# Clean up zombie containers from failed test runs
clean-containers:
    podman container prune -f || true

# === Aggregate Test Targets ===

# Run all contract tests (storage + bus)
# WHY: Complete validation of all backend implementations. The "did we break
# anything?" check before merging infrastructure changes.
test-contract: _storage-all _bus-all
    @echo "All contract tests passed"

# Basic clean - cargo target and generated proto code
clean:
    cargo clean
    rm -rf generated/

# Thorough clean - remove all build artifacts, caches, and stale directories
clean-all:
    @echo "=== Cleaning cargo target ==="
    cargo clean
    @echo "=== Cleaning generated proto code ==="
    rm -rf generated/
    @echo "=== Cleaning container cargo cache ==="
    rm -rf .cargo-container/registry .cargo-container/git
    @echo "=== Cleaning Python venvs ==="
    rm -rf .venv client/*/.venv
    @echo "=== Cleaning stale extracted directories ==="
    rm -rf client/ examples/
    @echo "=== Cleaning docs ==="
    rm -rf docs/build docs/.docusaurus docs/node_modules
    rm -f docs/static/container-overlay.tar.gz
    @echo "=== Cleaning OpenTofu provider caches ==="
    find deploy/tofu -name ".terraform" -type d -exec rm -rf {} + 2>/dev/null || true
    @echo "=== Cleaning vector search ==="
    rm -rf .vectors/
    @echo "=== Cleaning linter caches ==="
    rm -rf .ruff_cache .pytest_cache
    @echo "=== Cleaning mutation output ==="
    rm -rf mutants.out mutants.out.old
    @echo "=== Cleaning container images ==="
    podman image prune -f || docker image prune -f || true
    podman container prune -f || docker container prune -f || true
    @echo "=== Clean complete ==="

# === Coverage ===
# Uses cargo-llvm-cov for accurate line/branch coverage.
# Excludes: proto generated code, build.rs, main.rs binaries.

COV_IGNORE := "--ignore-filename-regex '(proto/|build\\.rs|main\\.rs)'"
COV_FEATURES := "--features 'sqlite test-utils'"

# Run unit tests with coverage
cov-unit:
    cargo llvm-cov --lib {{COV_FEATURES}} {{COV_IGNORE}}

# Run standalone integration tests with coverage
cov-integration:
    cargo llvm-cov --test standalone_integration {{COV_FEATURES}} {{COV_IGNORE}}

# Run interface/Gherkin tests with coverage
cov-gherkin:
    cargo llvm-cov --test interfaces {{COV_FEATURES}} {{COV_IGNORE}}

# Run all local tests with coverage (unit + integration + gherkin + client)
cov:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}}

# Quick terminal summary of coverage (all local tests)
cov-summary:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --summary-only

# Generate HTML coverage report (all local tests)
cov-html:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --html
    @echo "Coverage report generated at target/llvm-cov/html/index.html"

# Generate LCOV format for CI integration
cov-lcov:
    cargo llvm-cov \
        --workspace \
        --lib \
        --test standalone_integration \
        --test interfaces \
        {{COV_FEATURES}} \
        {{COV_IGNORE}} \
        --lcov --output-path target/llvm-cov/lcov.info

# === Contract Test Coverage (requires testcontainers/docker socket) ===

# Run PostgreSQL contract tests with coverage
cov-contract-postgres:
    cargo llvm-cov --test interfaces --features "postgres test-utils" {{COV_IGNORE}}

# Run Redis contract tests with coverage
cov-contract-redis:
    cargo llvm-cov --test interfaces --features "redis test-utils" {{COV_IGNORE}}

# Run AMQP bus contract tests with coverage
cov-contract-amqp:
    cargo llvm-cov --test bus_amqp --features amqp {{COV_IGNORE}} -- --test-threads=1

# Run Kafka bus contract tests with coverage
cov-contract-kafka:
    cargo llvm-cov --test bus_kafka --features kafka {{COV_IGNORE}} -- --test-threads=1

# Run all contract tests with combined coverage (requires docker socket)
cov-contracts:
    cargo llvm-cov \
        --test interfaces \
        --test bus_amqp \
        --features "postgres test-utils amqp" \
        {{COV_IGNORE}} \
        -- --test-threads=1

# === Full Coverage (all test types) ===

# Run all tests with combined coverage (local + contracts, requires docker socket)
cov-full:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}}

# Full coverage with HTML report (requires docker socket)
cov-full-html:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}} \
        --html
    @echo "Full coverage report generated at target/llvm-cov/html/index.html"

# Full coverage summary (requires docker socket)
cov-full-summary:
    cargo llvm-cov \
        --lib \
        --test standalone_integration \
        --test interfaces \
        --test bus_amqp \
        --features "sqlite postgres test-utils amqp" \
        {{COV_IGNORE}} \
        --summary-only

# === Mutation Testing ===
# Uses cargo-mutants to verify test quality by introducing mutations.
# Mutations that aren't caught by tests indicate weak test coverage.
# Output: mutants.out/ (gitignored)
#
# Uses --in-place to avoid copying the entire workspace (saves ~200GB disk).
# Safe because mutations are reverted after each test.

MUTANTS_TIMEOUT := "120"
MUTANTS_FEATURES := "--features 'sqlite test-utils'"

# Regenerate exclude_re patterns from #[trivial_delegation] attributes
gen-mutants-exclude:
    cargo xtask gen-mutants-exclude

# Run mutation tests on a specific file
mutants FILE: gen-mutants-exclude
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f {{FILE}} \
        -- {{MUTANTS_FEATURES}}

# Run mutation tests on handlers/core (aggregate, projector, saga, PM)
mutants-core: gen-mutants-exclude
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/handlers/core/aggregate.rs \
        -f src/handlers/core/projector.rs \
        -f src/handlers/core/saga.rs \
        -f src/handlers/core/process_manager.rs \
        -- {{MUTANTS_FEATURES}}
    @just mutants-summary

# Alias for backwards compatibility
mutants-handlers: mutants-core

# Run mutation tests on bus module (event routing)
mutants-bus: gen-mutants-exclude
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/bus/traits.rs \
        -f src/bus/mod.rs \
        -- {{MUTANTS_FEATURES}}

# Run mutation tests on orchestration (saga, aggregate, PM)
mutants-orchestration: gen-mutants-exclude
    cargo mutants \
        --in-place \
        --timeout {{MUTANTS_TIMEOUT}} \
        -f src/orchestration/saga/mod.rs \
        -f src/orchestration/aggregate/mod.rs \
        -f src/orchestration/process_manager/mod.rs \
        -- {{MUTANTS_FEATURES}}

# Show mutation testing summary
mutants-summary:
    @if [ -f mutants.out/outcomes.json ]; then \
        caught=$$(jq '[.outcomes[] | select(.summary == "CaughtMutant")] | length' mutants.out/outcomes.json); \
        missed=$$(jq '[.outcomes[] | select(.summary == "MissedMutant")] | length' mutants.out/outcomes.json); \
        unviable=$$(jq '[.outcomes[] | select(.summary == "Unviable")] | length' mutants.out/outcomes.json); \
        total=$$((caught + missed)); \
        if [ $$total -gt 0 ]; then \
            rate=$$((100 * caught / total)); \
        else \
            rate=0; \
        fi; \
        echo ""; \
        echo "=== Mutation Testing Summary ==="; \
        echo "Caught (killed): $$caught"; \
        echo "Missed (survived): $$missed"; \
        echo "Unviable (won't compile): $$unviable"; \
        echo "Kill rate: $$rate% ($$caught/$$total viable)"; \
        echo ""; \
        if [ $$missed -gt 0 ]; then \
            echo "=== Surviving Mutants ==="; \
            jq -r '.outcomes[] | select(.summary == "MissedMutant") | .scenario' mutants.out/outcomes.json; \
        fi; \
    else \
        echo "No mutation results found. Run 'just mutants-core' first."; \
    fi

# List surviving mutants (mutations not caught by tests)
mutants-survivors:
    @if [ -f mutants.out/outcomes.json ]; then \
        jq -r '.outcomes[] | select(.summary == "MissedMutant") | .scenario' mutants.out/outcomes.json; \
    else \
        echo "No mutation results found. Run 'just mutants-core' first."; \
    fi

