# Example terraform.tfvars for GitHub configuration
#
# Copy this file to terraform.tfvars and fill in actual values.
# NEVER commit terraform.tfvars with real secrets!
#
# For secrets management, consider:
# - Using environment variables: TF_VAR_actions_secrets='{"KEY":"value"}'
# - Using a secrets manager integration
# - Using SOPS/age encrypted tfvars files

github_owner    = "angzarr-io"
repository_name = "angzarr"

# Repository-level secrets
# These are available to all workflows
actions_secrets = {
  # Example: Docker Hub credentials
  # DOCKERHUB_USERNAME = "your-username"
  # DOCKERHUB_TOKEN    = "your-token"

  # Example: Cloud provider credentials
  # AWS_ACCESS_KEY_ID     = "AKIA..."
  # AWS_SECRET_ACCESS_KEY = "..."
  # GCP_SA_KEY            = "..."
}

# Staging environment
staging_secrets = {
  # Staging-specific secrets
  # DATABASE_URL = "postgres://..."
}

staging_variables = {
  CLUSTER_NAME = "angzarr-staging"
  REGION       = "us-central1"
}

# Production environment
production_secrets = {
  # Production-specific secrets
  # DATABASE_URL = "postgres://..."
}

production_variables = {
  CLUSTER_NAME = "angzarr-prod"
  REGION       = "us-central1"
}

# Webhooks
webhooks = {
  # Example: Discord notifications
  # discord = {
  #   url    = "https://discord.com/api/webhooks/..."
  #   events = ["push", "pull_request", "release"]
  # }

  # Example: Slack notifications
  # slack = {
  #   url    = "https://hooks.slack.com/services/..."
  #   events = ["push", "pull_request"]
  #   secret = "webhook-secret"
  # }
}
