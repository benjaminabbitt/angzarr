# Kind cluster management for angzarr development

set shell := ["bash", "-c"]

TOP := `git rev-parse --show-toplevel`
CLUSTER_NAME := "angzarr"
NAMESPACE := "angzarr"

default:
    @just --list

# === Cluster Lifecycle ===

# Create Kind cluster
create:
    #!/usr/bin/env bash
    if kind get clusters 2>/dev/null | grep -q "^{{CLUSTER_NAME}}$"; then
        echo "Cluster '{{CLUSTER_NAME}}' already exists"
    else
        kind create cluster --config "{{TOP}}/kind-config.yaml" --name {{CLUSTER_NAME}}
    fi

# Delete Kind cluster
delete:
    kind delete cluster --name {{CLUSTER_NAME}}

# Show cluster status
status:
    @echo "=== Cluster Info ==="
    @kubectl cluster-info --context kind-{{CLUSTER_NAME}} 2>/dev/null || echo "Cluster not running"
    @echo ""
    @echo "=== Nodes ==="
    @kubectl get nodes -o wide 2>/dev/null || true
    @echo ""
    @echo "=== Namespaces ==="
    @kubectl get namespaces 2>/dev/null || true

# === Namespace Setup ===

# Create angzarr namespace
namespace:
    kubectl create namespace {{NAMESPACE}} --dry-run=client -o yaml | kubectl apply -f -

# === Infrastructure (Bus + Storage) ===

# Deploy RabbitMQ
rabbit: namespace
    helm upgrade --install angzarr-mq "{{TOP}}/deploy/k8s/helm/rabbitmq" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy Kafka (requires Strimzi operator)
kafka: namespace operators
    helm upgrade --install angzarr-mq "{{TOP}}/deploy/k8s/helm/kafka" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy NATS
nats: namespace
    helm upgrade --install angzarr-mq "{{TOP}}/deploy/k8s/helm/nats" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy PostgreSQL
postgres: namespace
    helm upgrade --install angzarr-db "{{TOP}}/deploy/k8s/helm/postgres" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy Redis
redis: namespace
    helm upgrade --install angzarr-redis "{{TOP}}/deploy/k8s/helm/redis" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy operators (Strimzi for Kafka, CloudNative-PG)
operators:
    helm upgrade --install angzarr-operators "{{TOP}}/deploy/k8s/helm/operators" \
        --namespace operators --create-namespace \
        --wait --timeout 5m

# === Infra Presets ===

# Deploy standard infra: Rabbit + Postgres + Redis
infra-standard: rabbit postgres redis
    @echo "Standard infrastructure deployed (RabbitMQ + PostgreSQL + Redis)"

# Deploy Kafka infra: Kafka + Postgres + Redis
infra-kafka: kafka postgres redis
    @echo "Kafka infrastructure deployed (Kafka + PostgreSQL + Redis)"

# Deploy NATS infra: NATS + Postgres + Redis
infra-nats: nats postgres redis
    @echo "NATS infrastructure deployed (NATS + PostgreSQL + Redis)"

# === Application Deployment ===

# Deploy angzarr framework (sidecars)
framework: namespace
    helm upgrade --install angzarr "{{TOP}}/deploy/k8s/helm/angzarr" \
        --namespace {{NAMESPACE}} \
        --wait --timeout 5m

# Deploy a domain (usage: just kind deploy-domain player image=ghcr.io/angzarr-io/player-agg:latest)
deploy-domain name image: namespace
    helm upgrade --install {{name}} "{{TOP}}/deploy/k8s/helm/angzarr-domain" \
        --namespace {{NAMESPACE}} \
        --set domain={{name}} \
        --set aggregate.image={{image}} \
        --wait --timeout 5m

# Deploy a process manager
deploy-pm name image subscriptions targets: namespace
    helm upgrade --install {{name}} "{{TOP}}/deploy/k8s/helm/angzarr-pm" \
        --namespace {{NAMESPACE}} \
        --set name={{name}} \
        --set image={{image}} \
        --set "subscriptions={{subscriptions}}" \
        --set "targets={{targets}}" \
        --wait --timeout 5m

# === Full Stack Presets ===

# Full setup: cluster + standard infra + framework
up: create network-check infra-standard framework
    @echo ""
    @echo "=== Angzarr Ready ==="
    @kubectl get pods -n {{NAMESPACE}}

# Full setup with Kafka
up-kafka: create network-check infra-kafka framework
    @echo ""
    @echo "=== Angzarr Ready (Kafka) ==="
    @kubectl get pods -n {{NAMESPACE}}

# Tear down everything
down:
    helm uninstall angzarr -n {{NAMESPACE}} 2>/dev/null || true
    helm uninstall angzarr-mq -n {{NAMESPACE}} 2>/dev/null || true
    helm uninstall angzarr-db -n {{NAMESPACE}} 2>/dev/null || true
    helm uninstall angzarr-redis -n {{NAMESPACE}} 2>/dev/null || true
    helm uninstall angzarr-operators -n operators 2>/dev/null || true
    kubectl delete namespace {{NAMESPACE}} 2>/dev/null || true

# Nuclear option: delete cluster entirely
nuke: delete

# === Network Diagnostics ===

# Check if Kind cluster can reach the internet (required for pulling images)
network-check:
    #!/usr/bin/env bash
    echo "=== Checking network connectivity from Kind cluster ==="
    echo ""
    echo "Testing DNS resolution..."
    if podman exec {{CLUSTER_NAME}}-control-plane timeout 5 curl -s -I https://registry-1.docker.io/v2/ 2>/dev/null | head -1 | grep -q "HTTP"; then
        echo "✓ Can reach Docker Hub"
    else
        echo "✗ Cannot reach Docker Hub"
        echo ""
        echo "This is a common issue with Podman + Kind. Fixes (require sudo):"
        echo "  1. Enable IP forwarding: sudo sysctl -w net.ipv4.ip_forward=1"
        echo "  2. Check firewall: sudo firewall-cmd --add-masquerade --permanent"
        echo "  3. Or use: sudo nft add rule ip nat POSTROUTING oifname \"eth*\" masquerade"
        echo ""
        echo "See: https://github.com/kubernetes-sigs/kind/issues/2988"
        exit 1
    fi
    echo ""
    echo "Testing GitHub Container Registry..."
    if podman exec {{CLUSTER_NAME}}-control-plane timeout 5 curl -s -I https://ghcr.io/v2/ 2>/dev/null | head -1 | grep -q "HTTP"; then
        echo "✓ Can reach ghcr.io"
    else
        echo "✗ Cannot reach ghcr.io"
        exit 1
    fi
    echo ""
    echo "Network connectivity OK!"

# === Debugging ===

# Show all pods
pods:
    kubectl get pods -n {{NAMESPACE}} -o wide

# Show all services
services:
    kubectl get svc -n {{NAMESPACE}}

# Show logs for a pod (usage: just kind logs player-agg-xxx)
logs pod:
    kubectl logs -n {{NAMESPACE}} {{pod}} -f

# Exec into a pod (usage: just kind exec player-agg-xxx)
exec pod:
    kubectl exec -it -n {{NAMESPACE}} {{pod}} -- /bin/sh

# Port forward gateway
port-forward-gateway:
    @pkill -f "kubectl.*port-forward.*gateway" || true
    kubectl port-forward -n {{NAMESPACE}} svc/angzarr-gateway 9084:9084 &
    @echo "Gateway available at localhost:9084"

# Port forward RabbitMQ management UI
port-forward-rabbit:
    @pkill -f "kubectl.*port-forward.*rabbitmq" || true
    kubectl port-forward -n {{NAMESPACE}} svc/angzarr-mq-rabbitmq 15672:15672 &
    @echo "RabbitMQ UI available at localhost:15672 (user: guest, pass: guest)"
