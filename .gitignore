/target
**/target/
.cargo-container/
*.swp
*.swo
.DS_Store
*.db
*-shm
*-wal
/data/

# Example runtime artifacts
examples/*/data/
examples/*/*/data/
examples/*/*.txt
examples/*/*/*.txt
examples/*/tmp/
examples/*/*/tmp/
.plan/
.tasks/

# Secrets - never commit
.env
*.tfvars
!*.tfvars.example
secrets/
*-secrets.yaml
*-credentials.yaml
deploy/helm/angzarr/values-secrets.yaml
**/k8s/secrets.yaml

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Go build artifacts
*.so
*.h
!build/**/*.h

# C++ build artifacts
examples/cpp/build/
client/cpp/build/

# C# build artifacts
**/obj/
**/bin/

# Java build artifacts
**/build/
!/build/
!/build/images/
!/build/images/**
.gradle/

# Generated proto files (regenerated during build)
/generated/

# Go - protoc-gen-go output
**/*.pb.go

# Python - grpcio-tools output
**/*_pb2.py
**/*_pb2_grpc.py

# C++ - protoc output (kept in build/ dirs which are already ignored)
# **/*.pb.cc
# **/*.pb.h

# TypeScript/JavaScript - protoc-gen-ts output
**/*_pb.js
**/*_pb.d.ts
**/*_grpc_pb.js
**/*_grpc_pb.d.ts

# Java/Kotlin - protoc output goes to build/ (already ignored via **/build/)
# C# - protoc output goes to obj/ (already ignored via **/obj/)

# Example proto copies (canonical source: proto/)
examples/go/proto/
examples/python/proto/
examples/csharp/proto/
examples/kotlin/proto/
examples/typescript/proto/
examples/ruby/proto/
examples/java/proto/

# Python examples - generated protos (per-service)
examples/python/*/angzarr/
examples/python/*/proto/

# Go examples - generated protos (per-service)
examples/go/*/proto/

# Terraform
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.*

# IDE
.vscode/
.idea/
*.ipr
*.iws
*.iml

# Backup files
*.bak
*.orig
*~


.scm/sessions/

# Vector database (local Qdrant storage for MCP semantic search)
.vectors/

